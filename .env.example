# Telegram bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token

# Letta API key
LETTA_API_KEY=your_letta_api_key

# Sammie's agent ID on Letta Cloud
AGENT_ID=your_agent_id

# Letta API base URL (default: https://api.letta.com)
LETTA_API_BASE_URL=https://api.letta.com

# David's Telegram chat ID (for notifications)
GMAIL_CHAT_ID=your_telegram_chat_id
